str: @str
// Double curried continuation
printf: (fmt: str!, args: ..., ok:()) {
    (s: str) = @sprintf(fmt, args)
    @write(s, ok)
}
foo: (ok:(str)){
    ok("charlie")
}
baz: (ok:(str, str)){
    foo(ok("bob"))
}
bar: (name0: str, name1: str, name2: str){
    printf("hello %s, %s and %s\n", name0, name1, name2)
}
baz(bar("alice"))
