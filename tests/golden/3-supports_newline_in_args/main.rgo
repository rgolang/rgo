str: @str
int: @int
exit: @exit
printf: (fmt: str!, args: ..., ok:()) {
    (s: str) = @sprintf(fmt, args)
    @write(s, ok)
}
add: @add

as_int: (x:int, ok:(int), (str)){
    ok(x)
}
int_or_str: ((int), (str))
foo: (x: int_or_str, ok:()){
    x( 
        (x: int){
            printf("number: %d", x, ok)
        },
        (x: str){
            printf("x is str: %s\n", x, ok)
        }
    )
}
main: () {
    foo(as_int(42), exit(0))
}
