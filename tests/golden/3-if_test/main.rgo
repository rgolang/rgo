str: @str
int: @int
eqi: @eq
write: @write
printf: (fmt: str!, args: ..., ok:()) {
    (s: str) = @sprintf(fmt, args)
    @write(s, ok)
}
exit: @exit

true: (x: (), y: ()){
    x()
}
false: (x: (), y: ()){
    y()
}
if: (cond: ((),()), yes:(), no:()){
    cond(yes, no)
}
main: () {
    () = if(true, {
        printf("works", exit(0))
    })
    printf("doesn't work", exit(0))
}
