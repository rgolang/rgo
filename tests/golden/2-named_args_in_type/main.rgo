str: @str
exit: @exit
printf: (fmt: str!, args: ..., ok:()) {
    (s: str) = @sprintf(fmt, args)
    @write(s, ok)
}
foo: (a: str, b: str, c:str){
    printf("%s %s and %s", a, b, c, exit(0))
}
baz: (ok:(str)){
    ok("hello")
}
bar: (ok:(x:str, y:str)){
    baz(ok(y:"bob"))
}
main: () {
    bar(foo(b: "world"))
}
