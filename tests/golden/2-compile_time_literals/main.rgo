str: @str
int: @int
printf: (fmt: str!, args: ..., ok:()) {
    (s: str) = @sprintf(fmt, args)
    @write(s, ok)
}
exit: @exit

not_const_msg: (fmt: str!, value: int!) {
    printf(fmt, value, exit(0))
}
const_msg: (fmt: str!, value: int!) {
    not_const_msg(fmt, value)
}
main: () {
    const_msg("compile-time value %d\n", 7)
}
