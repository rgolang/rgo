str: @str
printf: (fmt: str!, args: ..., ok:()) {
    (s: str) = @sprintf(fmt, args)
    @write(s, ok)
}
exit: @exit

true: (x: (), y: ()){
    x()
}
false: (x: (), y: ()){
    y()
}
if: (cond: ((),()), on_true:()){
    cond(on_true, printf("does not work\n", exit(0)))
}
main: () {
    if(true, printf("works\n", exit(0)))
}
