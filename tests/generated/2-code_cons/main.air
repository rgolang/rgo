main():
    @exit($_4: int = 0)


main_unwrapper($env_end: int):
    $__env_end = @pin($env_end)
    @release($__env_end)
    @jumpargs(main)


main_deep_release($env_end: int):
    $__env_end = @pin($env_end)
    @release($__env_end)
    @return()


main_deepcopy($env_end: int):
    $__env_end = @pin($env_end)
    @return()


_start():
    @jumpargs(main)

